[database]
url = "postgresql:///helioryn_dev?host=/tmp"

[cache]
url = "redis://localhost:6379/0"

[auth]
api_key = "c54c906a-52a2-4dee-beb0-7e917f13defe"
admin_password = "admin"
session_secret = "helioryn-dev-secret"

[grounding]
wikidata_enabled = true
factcheck_enabled = true
factcheck_provider = "google"
factcheck_api_key = "AIzaSyCe7iVeQTq1rmSzBRK_Q9dAEZ5NnIBs2I0"

[ingest]
fetch_delay = 0.3
auto_generate_queries = false
domain_denylist = ["msn.com", "aol.com", "yahoo.com", "finance.yahoo.com",
    "markets.businessinsider.com", "247wallst.com", "prnewswire.com",
    "cryptobriefing.com"]

[ingest.searcher]
type = "searxng"
base_url = "http://localhost:8888"
categories = "general,news,science"
language = "en"

[ingest.fetcher]
type = "http"
timeout = 30.0
user_agent = "Helioryn/0.1"

[ingest.normalizer]
type = "readability"

[ingest.ingestor]
type = "postgres"

[ingest.topics]
items = [
    # ====================================================================
    # Artificial Intelligence (ai topic — tier 1 core)
    # ====================================================================

    # --- Models ---
    { query = "GPT AI model", interval_minutes = 120, language = "en", category = "Models" },
    { query = "LLaMA open source", interval_minutes = 120, language = "en", category = "Models" },
    { query = "DeepSeek AI", interval_minutes = 120, language = "en", category = "Models" },
    { query = "Claude Anthropic", interval_minutes = 120, language = "en", category = "Models" },
    { query = "Gemini Google", interval_minutes = 120, language = "en", category = "Models" },
